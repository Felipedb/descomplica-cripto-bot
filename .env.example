# Copie este arquivo para .env e preencha com seus dados.
# NUNCA suba o .env real para o GitHub (ja esta no .gitignore).

# Token do bot, obtido no @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWxyz

# Destino da mensagem. Para o canal publico use o @usuario:
TELEGRAM_CHAT_ID=@descomplicabtc

# (Opcional) Destino so das NOTICIAS (news_bot.py). Pode ser um canal separado.
# Se ficar vazio, o bot de noticias usa o TELEGRAM_CHAT_ID acima.
TELEGRAM_NEWS_CHAT_ID=

# (Opcional) Chave do plano Demo do CoinGecko para aumentar o rate limit.
# Funciona sem ela. Crie em https://www.coingecko.com/en/developers/dashboard
COINGECKO_DEMO_KEY=
